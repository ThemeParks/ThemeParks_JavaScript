{
  "name": "themeparks",
  "version": "7.0.0-alpha.2",
  "description": "Official SDK for the ThemeParks.wiki API",
  "license": "MIT",
  "repository": "github:ThemeParks/ThemeParks_JavaScript",
  "homepage": "https://api.themeparks.wiki",
  "bugs": "https://github.com/ThemeParks/ThemeParks_JavaScript/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "MIGRATION.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run test/unit",
    "test:watch": "vitest test/unit",
    "test:live": "vitest run test/live",
    "lint": "eslint src test scripts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "regenerate": "tsx scripts/regenerate.ts",
    "docs": "typedoc",
    "docs:serve": "npx serve docs-site",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.2.0",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
